{
  "name": "porest-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "design.md lint DESIGN.md",
    "lint:hr": "design.md lint DESIGN.hr.md",
    "lint:desk": "design.md lint DESIGN.desk.md",
    "lint:all": "npm run lint && npm run lint:hr && npm run lint:desk",
    "diff": "design.md diff DESIGN.history/$(ls -t DESIGN.history | head -1) DESIGN.md",
    "export:tailwind": "design.md export --format css-tailwind DESIGN.md > exports/tokens.css",
    "export:tailwind:hr": "design.md export --format css-tailwind DESIGN.hr.md > exports/tokens-hr.css",
    "export:tailwind:desk": "design.md export --format css-tailwind DESIGN.desk.md > exports/tokens-desk.css",
    "export:dtcg": "design.md export --format dtcg DESIGN.md > exports/tokens.json",
    "snapshot": "cp DESIGN.md DESIGN.history/v$(date +%Y%m%d-%H%M%S).md"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1"
  }
}
